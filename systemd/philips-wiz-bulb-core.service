[Unit]
Description=philips-wiz-bulb-core — Philips WiZ smart-bulb control daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=-%h/.config/philips-wiz-bulb/state.env
ExecStart=%h/.local/bin/philips-wiz-bulb-core serve
Restart=on-failure
RestartSec=5

# Hardening (only flags that work in user-scope; see
# feedback_systemd_user_hardening in user memory)
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=%h/.config/philips-wiz-bulb

[Install]
WantedBy=default.target
