# Copy to ~/.config/philips-wiz-bulb/state.env and adjust to your LAN.
# This file is committed; the real one is NOT.

# Daemon bind
# PHILIPS_WIZ_BULB_BIND=127.0.0.1:8766

# Discovery (defaults assume 192.168.1.0/24)
# PHILIPS_WIZ_BULB_BROADCAST=192.168.1.255
# PHILIPS_WIZ_BULB_SUBNET=192.168.1.0/24

# Refresh + re-discover cadences (seconds)
# PHILIPS_WIZ_BULB_REFRESH_INTERVAL_S=60
# PHILIPS_WIZ_BULB_DISCOVER_INTERVAL_S=600

# Logging + state
# PHILIPS_WIZ_BULB_LOG_LEVEL=INFO
# PHILIPS_WIZ_BULB_STATE_DIR=~/.config/philips-wiz-bulb
